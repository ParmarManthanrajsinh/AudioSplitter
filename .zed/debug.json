// Project-local debug tasks
//
// For more documentation on how to configure debug tasks,
// see: https://zed.dev/docs/debugger
[
  {
    "label": "Debug native binary",
    "build": {
      "command": "cmake",
      "args": ["--build", "build/debug"],
      "cwd": "$ZED_WORKTREE_ROOT"
    },
    "program": "$ZED_WORKTREE_ROOT/build/debug/AudioSplitter.exe",
    "request": "launch",
    "adapter": "CodeLLDB"
  },
  {
    "label": "Release native binary",
    "build": {
      "command": "cmake",
      "args": ["--build", "build/release"],
      "cwd": "$ZED_WORKTREE_ROOT"
    },
    "program": "$ZED_WORKTREE_ROOT/build/release/AudioSplitter.exe",
    "request": "launch",
    "adapter": "CodeLLDB"
  }
]

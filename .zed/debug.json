[
  {
    "label": "Debug native binary",
    "build": {
      "command": "cmake",
      "args": [
        "--build",
        "build/debug"
      ],
      "cwd": "$ZED_WORKTREE_ROOT"
    },
    "program": "$ZED_WORKTREE_ROOT/build/debug/AudioSplitter.exe",
    "request": "launch",
    "adapter": "CodeLLDB"
  },
  {
    "label": "Release native binary",
    "build": {
      "command": "cmake",
      "args": [
        "--build",
        "build/release"
      ],
      "cwd": "$ZED_WORKTREE_ROOT"
    },
    "program": "$ZED_WORKTREE_ROOT/build/release/AudioSplitter.exe",
    "request": "launch",
    "adapter": "CodeLLDB"
  },
  {
    "label": "Clean Debug Build",
    "build": {
      "command": "cmake",
      "args": [
        "--build",
        "build/debug",
        "--clean-first"
      ],
      "cwd": "$ZED_WORKTREE_ROOT"
    },
    "program": "$ZED_WORKTREE_ROOT/build/debug/AudioSplitter.exe",
    "request": "launch",
    "adapter": "CodeLLDB"
  },
  {
    "label": "Clean Release Build",
    "build": {
      "command": "cmake",
      "args": [
        "--build",
        "build/release",
        "--clean-first"
      ],
      "cwd": "$ZED_WORKTREE_ROOT"
    },
    "program": "$ZED_WORKTREE_ROOT/build/release/AudioSplitter.exe",
    "request": "launch",
    "adapter": "CodeLLDB"
  }
]